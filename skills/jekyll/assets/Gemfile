source "https://rubygems.org"

# Jekyll 4.x — use this Gemfile when you control the build
# (Netlify, Cloudflare Pages, GitHub Actions, manual deploy).
# If you push source to GitHub Pages classic, use github-pages.Gemfile instead.

gem "jekyll", "~> 4.4.1"

group :jekyll_plugins do
  gem "jekyll-feed",          "~> 0.17"
  gem "jekyll-seo-tag",       "~> 2.8"
  gem "jekyll-sitemap",       "~> 1.4"
  gem "jekyll-redirect-from", "~> 0.16"
  gem "jekyll-paginate-v2",   "~> 3.0"
end

# Ruby 3+ removed webrick from stdlib; Jekyll's dev server needs it.
gem "webrick", "~> 1.9"

# Lock Sass to avoid surprise deprecation breakage in older themes.
# Bump deliberately when you're ready to migrate @import -> @use.
gem "sass-embedded", "~> 1.77"

# Performance helpers
gem "jekyll-include-cache", "~> 0.2"

# Windows / JRuby compatibility
platforms :mingw, :x64_mingw, :mswin, :jruby do
  gem "tzinfo", ">= 1", "< 3"
  gem "tzinfo-data"
end
gem "wdm", "~> 0.1", platforms: [:mingw, :x64_mingw, :mswin]

# HTTP parser performance lock — sometimes needed on macOS for older Rubies.
# Uncomment only if you hit "http_parser.rb" build errors:
# gem "http_parser.rb", "~> 0.6.0"
